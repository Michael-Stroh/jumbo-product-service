@page "/products"
@rendermode InteractiveServer
@inject ProductListViewModel Vm
@inject IJSRuntime JS

<PageTitle>Products</PageTitle>
<h1>Products</h1>

<div class="mb-3 d-flex gap-2">
    <a class="btn btn-primary" href="products/create">New Product</a>
    <a class="btn btn-secondary" href="products/import">Import</a>
</div>

@if (Vm.Error is not null)
{
    <div class="alert alert-danger">@Vm.Error</div>
}

@if (Vm.Products is null && Vm.Error is null)
{
    <div class="spinner-border text-warning" role="status">
        <span class="visually-hidden">Loading…</span>
    </div>
}
else if (Vm.Products is { Count: 0 })
{
    <p class="text-muted">No products found.</p>
}
else if (Vm.Products is not null)
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Category</th>
                <th>Active</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Vm.Products)
            {
                <tr>
                    <td>@p.Code</td>
                    <td>@p.Name</td>
                    <td>@((Category)p.Category)</td>
                    <td>@(p.IsActive ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" href="products/@p.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary ms-1" href="products/@p.Id/edit">Edit</a>
                        <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteAsync(p.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    protected override async Task OnInitializedAsync() => await Vm.LoadAsync();

    async Task DeleteAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this product?")) return;
        await Vm.DeleteAsync(id);
    }
}
