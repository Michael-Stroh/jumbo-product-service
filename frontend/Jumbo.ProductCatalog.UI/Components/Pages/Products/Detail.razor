@page "/products/{Id:guid}"
@rendermode InteractiveServer
@inject ProductDetailViewModel Vm

<PageTitle>@(Vm.Product?.Name ?? "Product")</PageTitle>

@if (Vm.IsLoading)
{
    <div class="spinner-border text-warning" role="status">
        <span class="visually-hidden">Loading…</span>
    </div>
}
else if (Vm.Error is not null)
{
    <h1>Product</h1>
    <div class="alert alert-danger">@Vm.Error</div>
    <a class="btn btn-outline-secondary" href="products">Back</a>
}
else if (Vm.Product is not null)
{
    <h1>@Vm.Product.Name</h1>
    <dl class="row">
        <dt class="col-sm-3">Code</dt>
        <dd class="col-sm-9">@Vm.Product.Code</dd>
        <dt class="col-sm-3">Category</dt>
        <dd class="col-sm-9">@((Category)Vm.Product.Category)</dd>
        <dt class="col-sm-3">Content</dt>
        <dd class="col-sm-9">@(Vm.Product.Content ?? "-")</dd>
        <dt class="col-sm-3">Active</dt>
        <dd class="col-sm-9">@(Vm.Product.IsActive ? "Yes" : "No")</dd>
        <dt class="col-sm-3">Created</dt>
        <dd class="col-sm-9">@Vm.Product.CreatedAt.ToString("g")</dd>
        <dt class="col-sm-3">Updated</dt>
        <dd class="col-sm-9">@Vm.Product.UpdatedAt.ToString("g")</dd>
    </dl>
    <a class="btn btn-primary" href="products/@Vm.Product.Id/edit">Edit</a>
    <a class="btn btn-outline-secondary ms-2" href="products">Back</a>
}

@code {
    [Parameter] public Guid Id { get; set; }

    protected override async Task OnInitializedAsync() => await Vm.LoadAsync(Id);
}
