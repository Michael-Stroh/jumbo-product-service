@page "/products/{Id:guid}/edit"
@rendermode InteractiveServer
@inject ProductFormViewModel Vm
@inject NavigationManager Nav

<PageTitle>Edit Product</PageTitle>
<h1>Edit Product</h1>

@if (Vm.IsLoading)
{
    <div class="spinner-border text-warning" role="status">
        <span class="visually-hidden">Loading…</span>
    </div>
}
else if (_loadFailed)
{
    <div class="alert alert-danger">@Vm.Error</div>
    <a class="btn btn-outline-secondary" href="products">Back</a>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <EditForm Model="Vm.Form" OnValidSubmit="SubmitAsync">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">Code</label>
                    <input class="form-control" value="@Vm.Form.Code" disabled />
                </div>
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="Vm.Form.Name" maxlength="50" />
                    <ValidationMessage For="() => Vm.Form.Name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Category</label>
                    <InputSelect class="form-select" @bind-Value="Vm.Form.Category">
                        @foreach (var c in Enum.GetValues<Category>())
                        {
                            <option value="@((int)c)">@c</option>
                        }
                    </InputSelect>
                </div>
                <div class="mb-3">
                    <label class="form-label">Content</label>
                    <InputTextArea class="form-control" @bind-Value="Vm.Form.Content" rows="3" />
                </div>
                <div class="mb-3 form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="Vm.Form.IsActive" id="isActive" />
                    <label class="form-check-label" for="isActive">Active</label>
                </div>

                @if (Vm.Error is not null)
                {
                    <div class="alert alert-danger">@Vm.Error</div>
                }

                <button type="submit" class="btn btn-primary" disabled="@Vm.IsSubmitting">
                    @if (Vm.IsSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Save
                </button>
                <a class="btn btn-outline-secondary ms-2" href="products">Cancel</a>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    bool _loadFailed;

    protected override async Task OnInitializedAsync()
    {
        await Vm.LoadProductAsync(Id);
        _loadFailed = Vm.Error is not null;
    }

    async Task SubmitAsync()
    {
        if (await Vm.SubmitUpdateAsync(Id))
            Nav.NavigateTo("products");
    }
}
