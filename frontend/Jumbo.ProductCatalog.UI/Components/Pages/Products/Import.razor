@page "/products/import"
@rendermode InteractiveServer
@inject ImportViewModel Vm

<PageTitle>Import Products</PageTitle>
<h1>Import Products</h1>

<p>
    Paste a JSON array of products. Category must be numeric: <code>0</code> = Food, <code>1</code> = NonFood.
</p>
<details class="mb-3">
    <summary class="text-secondary" style="cursor:pointer">Show example</summary>
    <pre class="mt-2 p-3 bg-light border rounded small">@_example</pre>
</details>

<div class="mb-3">
    <textarea class="form-control font-monospace" rows="14" @bind="Vm.Json" placeholder="Paste JSON array here…"></textarea>
</div>

@if (Vm.Error is not null)
{
    <div class="alert alert-danger">@Vm.Error</div>
}

@if (Vm.Result is not null)
{
    <div class="alert alert-success">
        <strong>Imported @Vm.Result.Processed product(s).</strong>
        @if (Vm.Result.SkippedCodes.Count > 0)
        {
            <div>Skipped (duplicate/invalid): @string.Join(", ", Vm.Result.SkippedCodes)</div>
        }
    </div>
}

<button class="btn btn-primary" @onclick="() => Vm.ImportAsync()"
        disabled="@(string.IsNullOrWhiteSpace(Vm.Json) || Vm.IsSubmitting)">
    @if (Vm.IsSubmitting)
    {
        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
    }
    Import
</button>
<a class="btn btn-outline-secondary ms-2" href="products">Back</a>

@code {
    const string _example = """
        [
          { "Code": "F1001", "Name": "Organic Bananas", "Category": 0, "Content": "Fresh organic bananas.", "IsActive": true },
          { "Code": "NF2001", "Name": "Detergent 1L",   "Category": 1, "Content": null,                    "IsActive": true }
        ]
        """;
}
