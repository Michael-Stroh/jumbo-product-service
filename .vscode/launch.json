{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": [
        ".NET Core Launch (API)",
        ".NET Core Launch (UI)"
      ]
    }
  ],
  "configurations": [
    {
      "name": ".NET Core Launch (UI)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "launchSettingsFilePath": "${workspaceFolder}/frontend/Jumbo.ProductCatalog.UI/Properties/launchSettings.json",
      "launchSettingsProfile": "http",
      "program": "${workspaceFolder}/frontend/Jumbo.ProductCatalog.UI/bin/Debug/net10.0/Jumbo.ProductCatalog.UI.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "launchBrowser": {
        "enabled": false
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": ".NET Core Launch (API)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "launchSettingsFilePath": "${workspaceFolder}/backend/Jumbo.ProductCatalog.Api/Properties/launchSettings.json",
      "launchSettingsProfile": "http",
      "program": "${workspaceFolder}/backend/Jumbo.ProductCatalog.Api/bin/Debug/net10.0/Jumbo.ProductCatalog.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/scalar/v1"
      },
      "launchBrowser": {
        "enabled": false
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
