root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_size = 4
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Naming: interfaces
dotnet_naming_rule.interfaces_should_begin_with_i.symbols = interface_symbols
dotnet_naming_rule.interfaces_should_begin_with_i.style = i_prefix_style
dotnet_naming_rule.interfaces_should_begin_with_i.severity = warning
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.i_prefix_style.required_prefix = I
dotnet_naming_style.i_prefix_style.capitalization = pascal_case

# Naming: async methods
dotnet_naming_rule.async_methods_end_in_async.symbols = async_method_symbols
dotnet_naming_rule.async_methods_end_in_async.style = async_suffix_style
dotnet_naming_rule.async_methods_end_in_async.severity = warning
dotnet_naming_symbols.async_method_symbols.applicable_kinds = method
dotnet_naming_symbols.async_method_symbols.required_modifiers = async
dotnet_naming_style.async_suffix_style.required_suffix = Async
dotnet_naming_style.async_suffix_style.capitalization = pascal_case

# var preferences
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = false:silent
csharp_style_expression_bodied_properties = true:suggestion

# Braces
csharp_prefer_braces = true:warning

[*.{json,yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
