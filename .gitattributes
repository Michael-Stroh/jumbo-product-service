# Auto-detect text files and normalize line endings
* text=auto

# Force LF for source files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.http text eol=lf
*.razor text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.pdb binary
