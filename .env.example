# Copy this file to .env and fill in values before running docker compose.
# .env is gitignored and should never be committed.

MSSQL_SA_PASSWORD=your-strong-password-here

# TODO: when API and Worker are added as docker compose services, these will be
# injected as environment variable overrides (Database__ConnectionString etc.).
# For now, set connection strings via dotnet user-secrets for local dotnet run.
# See docs/secrets-guide.md for instructions.
Database__ConnectionString=Server=localhost,1433;Database=JumboProductCatalog;User Id=sa;Password=your-strong-password-here;TrustServerCertificate=True
